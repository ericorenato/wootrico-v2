{
  "name": "@wootrico/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env src/main.ts",
    "build": "tsup",
    "start": "node --env-file-if-exists=../../.env dist/main.cjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@wootrico/cache": "workspace:*",
    "@wootrico/chatwoot-client": "workspace:*",
    "@wootrico/config": "workspace:*",
    "@wootrico/db": "workspace:*",
    "@wootrico/license-client": "workspace:*",
    "@wootrico/providers": "workspace:*",
    "@wootrico/queue": "workspace:*",
    "@wootrico/storage": "workspace:*",
    "@wootrico/types": "workspace:*",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0"
  },
  "optionalDependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
