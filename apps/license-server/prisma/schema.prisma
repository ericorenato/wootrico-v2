// license-server — vendor-hosted, separate database.

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("LICENSE_DATABASE_URL")
}

model LicenseKey {
  id             String       @id @default(uuid())
  keyHash        String       @unique @map("key_hash")
  // 'trial' (free, time-limited) or 'paid' (lifetime). Legacy rows ('pro' etc.)
  // are migrated to 'paid' so existing customers never expire.
  plan           String       @default("trial")
  email          String?
  name           String?
  provisionedBy  String       @default("admin") @map("provisioned_by")
  features       Json?
  maxActivations Int          @default(1) @map("max_activations")
  // Trial keys expire at this instant; paid (lifetime) keys leave it null.
  expiresAt      DateTime?    @map("expires_at")
  revokedAt      DateTime?    @map("revoked_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  activations    Activation[]

  @@map("license_keys")
}

model Activation {
  id              String     @id @default(uuid())
  licenseKeyId    String     @map("license_key_id")
  licenseKey      LicenseKey @relation(fields: [licenseKeyId], references: [id], onDelete: Cascade)
  instanceId      String     @map("instance_id")
  appVersion      String?    @map("app_version")
  publicBaseUrl   String?    @map("public_base_url")
  firstIp         String?    @map("first_ip")
  lastIp          String?    @map("last_ip")
  boundAt         DateTime   @default(now()) @map("bound_at")
  lastHeartbeatAt DateTime?  @map("last_heartbeat_at")
  lastTelemetry   Json?      @map("last_telemetry")
  revokedAt       DateTime?  @map("revoked_at")

  @@unique([licenseKeyId, instanceId])
  @@index([instanceId])
  @@map("activations")
}

/// Webhook authentication keys (payment provider → license server).
/// The vendor creates/rotates/revokes these in the admin panel; the raw key is
/// shown once and stored only as a SHA256 hash.
model WebhookKey {
  id         String    @id @default(uuid())
  keyHash    String    @unique @map("key_hash")
  name       String?
  lastUsedAt DateTime? @map("last_used_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("webhook_keys")
}

/// A pending/settled purchase tied to a specific installation. Created when the
/// customer clicks "buy" (we record which instanceId is buying); settled by the
/// payment webhook, which mints a paid key and delivers it back to that instance.
model PurchaseIntent {
  id           String    @id @default(uuid())
  instanceId   String    @map("instance_id")
  email        String?
  status       String    @default("pending") // pending | paid | cancelled
  licenseKeyId String?   @map("license_key_id")
  issuedKey    String?   @map("issued_key") // raw paid key, delivered to the client once
  paymentRef   String?   @map("payment_ref") // external id, for idempotency
  createdAt    DateTime  @default(now()) @map("created_at")
  paidAt       DateTime? @map("paid_at")

  @@index([email, status, createdAt])
  @@index([instanceId])
  @@map("purchase_intents")
}

model HeartbeatLog {
  id           String   @id @default(uuid())
  licenseKeyId String   @map("license_key_id")
  instanceId   String   @map("instance_id")
  telemetry    Json?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([licenseKeyId, createdAt])
  @@map("heartbeat_log")
}

/// Unified, LGPD-safe access/usage log. Stores only operational metadata
/// (event type, ip, app version, instanceId, timestamps) — never message
/// or conversation content.
model LicenseEvent {
  id           String   @id @default(uuid())
  licenseKeyId String?  @map("license_key_id")
  instanceId   String?  @map("instance_id")
  type         String
  ip           String?
  appVersion   String?  @map("app_version")
  meta         Json?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([licenseKeyId, createdAt])
  @@index([createdAt])
  @@map("license_events")
}
