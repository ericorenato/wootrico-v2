# ─────────────────────────────────────────────────────────────
# license-server (VENDOR-ONLY). Copy to apps/license-server/.env
# Keys come from: node scripts/gen-license-keys.mjs
# ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
HOST=0.0.0.0

# In docker-compose.license-server.yml the host is "license-postgres".
LICENSE_DATABASE_URL=postgresql://license:change-me@license-postgres:5432/license

# Ed25519 private key (base64 PEM) — keep this SECRET, only on the server.
LICENSE_PRIVATE_KEY=
# Public key (base64 PEM) — also embed this in the instance .env as LICENSE_PUBLIC_KEY.
LICENSE_PUBLIC_KEY=

# Bearer token protecting /admin/* (create/list/revoke keys). Use a long random value.
ADMIN_TOKEN=

LICENSE_TOKEN_TTL_DAYS=14
