# ─────────────────────────────────────────────────────────────
# license-server (VENDOR-ONLY). Copy to apps/license-server/.env
# Validation is fully ONLINE — no signing keys to generate.
# ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
HOST=0.0.0.0

# In docker-compose.license-server.yml the host is "license-postgres".
LICENSE_DATABASE_URL=postgresql://license:change-me@license-postgres:5432/license

# Bearer token protecting /admin/* (create/list/revoke keys via scripts/CLI).
# Use a long random value.
ADMIN_TOKEN=

# Admin web panel login (served at http://<host>:4000/). When both are set, the
# panel login issues a session JWT. Leave blank to disable the panel login (only
# ADMIN_TOKEN Bearer works then).
LICENSE_ADMIN_EMAIL=
LICENSE_ADMIN_PASSWORD=
# Secret used to sign admin panel session tokens. Defaults to ADMIN_TOKEN if unset.
LICENSE_ADMIN_JWT_SECRET=

# Initial trial lifetime in days. After it elapses the customer must buy a key.
LICENSE_TRIAL_DAYS=14

# Paid licenses are time-limited (default 1 year = 365 days). Each purchase or
# renewal grants this many days; the admin can override the date per key (or
# clear it to make a key lifetime).
LICENSE_PAID_DAYS=365

# Checkout URL the customer is sent to when buying (Hotmart). The server appends
# ?sck=<intentId> so the payment maps back even if the buyer's e-mail differs.
LICENSE_CHECKOUT_URL=https://pay.hotmart.com/F106461744G

# Hotmart Postback (webhook) token. In Hotmart, point the webhook 2.0 to
# https://<este-subdominio>/webhook/hotmart and paste its token here. Without it
# the Hotmart webhook rejects every call.
HOTMART_HOTTOK=
# Optional: only accept Hotmart events for this product id (extra safety).
HOTMART_PRODUCT_ID=

# Google login (optional). When both are set, customer instances can register/
# reactivate with "Entrar com Google". Create an OAuth 2.0 Client (Web app) in
# Google Cloud with redirect URI: https://<este-subdominio>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
