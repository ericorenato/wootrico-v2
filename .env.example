# ─────────────────────────────────────────────────────────────
# Wootrico v2 — variáveis de ambiente da instância
# Copie para .env e preencha. NUNCA faça commit do .env.
#
# Em produção (VPS) você normalmente NÃO edita isto à mão: o install.sh pergunta
# o necessário, gera os segredos e escreve o .env. Este arquivo é a referência
# para quem clona / sobe manualmente via docker-compose.
#
# Gere os segredos obrigatórios:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"     # APP_ENCRYPTION_KEY
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"  # JWT_SECRET
# ─────────────────────────────────────────────────────────────

# ───────────── OBRIGATÓRIOS (o app não sobe sem eles) ─────────────
# String de conexão do Postgres (host = nome do serviço na rede; porta interna).
DATABASE_URL=postgresql://wootrico:change-me@postgres:5432/wootrico?schema=public
# Segredo de sessão/JWT — mínimo 32 caracteres.
JWT_SECRET=
# Chave de criptografia das credenciais salvas — 32 bytes em base64 (ver acima).
APP_ENCRYPTION_KEY=

# ───────────── Postgres (consumido pelo container/compose) ─────────────
POSTGRES_USER=wootrico
POSTGRES_PASSWORD=change-me
POSTGRES_DB=wootrico

# ───────────── RabbitMQ (transporte; topologia criada no boot) ─────────────
# O vhost vai no final da URL: amqp://user:senha@host:5672/VHOST  (padrão: / → %2F).
# Senha/usuário com caracteres especiais (@ : / etc.) devem ser URL-encoded
# na URL (ex.: @ vira %40). Em servidores gerenciados, o vhost costuma ser nomeado.
RABBITMQ_USER=wootrico
RABBITMQ_PASSWORD=change-me
RABBITMQ_VHOST=/
RABBITMQ_URL=amqp://wootrico:change-me@rabbitmq:5672/%2F

# ───────────── Redis (lock por conversa + cache + throttle) ─────────────
# Geralmente sem senha. Com senha: redis://:SENHA@redis:6379 e defina REDIS_PASSWORD.
REDIS_URL=redis://redis:6379
# REDIS_PASSWORD=

# ───────────── Domínio / TLS (Traefik) ─────────────
# Domínio do painel + webhooks. Aponte um registro A para o IP da VPS antes de subir.
DOMAIN=wootrico.suaempresa.com
# E-mail do Let's Encrypt (usado quando o Wootrico instala o Traefik).
ACME_EMAIL=voce@suaempresa.com
# URL pública (também ajustável no setup wizard). Deve bater com o domínio.
PUBLIC_BASE_URL=https://wootrico.suaempresa.com

# ───────────── Licenciamento (provisionado pela aplicação) ─────────────
# NÃO é configurado no instalador: a ferramenta de licenciamento (a ser
# implementada) seta estes valores automaticamente. Deixe como abaixo.
LICENSE_REQUIRED=false
# LICENSE_SERVER_URL=
# LICENSE_PUBLIC_KEY=
# LICENSE_KEY=

# ───────────── Runtime do app (têm defaults; raramente mudam) ─────────────
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=production
APP_VERSION=0.1.0

# ───────────── Só para docker-compose.local.yml (Docker Desktop) ─────────────
# Porta do host onde o painel fica acessível (default pouco comum p/ evitar conflito).
PANEL_PORT=8789
RABBITMQ_UI_PORT=15673
# Para uso local, aponte a base pública para a porta escolhida:
# PUBLIC_BASE_URL=http://localhost:8789

# ───────────── Imagem multi-arch ─────────────
# A imagem publicada é multi-arch (amd64+arm64): o Docker baixa a variante nativa
# do seu host (sem emulação). Deixe vazio/comentado. Force só se necessário.
# WOOTRICO_PLATFORM=linux/amd64

# Obs.: o install.sh grava chaves auxiliares de bookkeeping (WOOTRICO_NETWORK,
# WOOTRICO_TRAEFIK, WOOTRICO_PG_MODE/HOST/PORT, etc.) — gerenciadas por ele.
