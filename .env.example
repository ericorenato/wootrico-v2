# ─────────────────────────────────────────────────────────────
# Wootrico v2 — instance environment (customer)
# Copy to .env and fill in. Never commit .env.
# Generate secrets:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"  # APP_ENCRYPTION_KEY
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))" # JWT_SECRET
# ─────────────────────────────────────────────────────────────

# Domain Traefik serves (auto-TLS via Let's Encrypt) + ACME email.
DOMAIN=wootrico.suaempresa.com
ACME_EMAIL=voce@suaempresa.com

# Postgres
POSTGRES_USER=wootrico
POSTGRES_PASSWORD=change-me
POSTGRES_DB=wootrico
DATABASE_URL=postgresql://wootrico:change-me@postgres:5432/wootrico?schema=public

# RabbitMQ (transporte de mensagens — topologia criada automaticamente no boot)
RABBITMQ_USER=wootrico
RABBITMQ_PASSWORD=change-me
RABBITMQ_URL=amqp://wootrico:change-me@rabbitmq:5672

# Redis (lock de ordenação por conversa + cache + throttle)
REDIS_URL=redis://redis:6379

# Public URL (também definida no setup wizard)
PUBLIC_BASE_URL=https://wootrico.suaempresa.com

# Central license server (vendor-hosted) + chave pública para validar tokens offline.
LICENSE_SERVER_URL=https://license.suaempresa.com
LICENSE_PUBLIC_KEY=
# Bloqueia o processamento até a licença estar ativa (recomendado em produção).
LICENSE_REQUIRED=true
# Opcional: pré-semear a chave (senão é informada no wizard).
# LICENSE_KEY=

# Secrets
JWT_SECRET=
APP_ENCRYPTION_KEY=

# HTTP
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=production
APP_VERSION=0.1.0
